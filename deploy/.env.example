# ─────────────────────────────────────────────────────────────────────────────
# Spectre Gold AI — Environment Variables Template
#
# Copy this file to .env and fill in your values.
# NEVER commit the filled-in .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google AI / Gemini ────────────────────────────────────────────────────────
# Your Gemini API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── ADK Agent Service ─────────────────────────────────────────────────────────
# URL of the deployed agent_service (Cloud Run or local).
# Leave EMPTY to use the local WorkflowRunner fallback.
#
# Local development:
#   ADK_AGENT_SERVICE_URL=http://localhost:8020
#
# Cloud Run:
#   ADK_AGENT_SERVICE_URL=https://spectre-gold-agent-xxxx-uc.a.run.app
ADK_AGENT_SERVICE_URL=

# ── Genkit Flow Service ───────────────────────────────────────────────────────
# URL of the Genkit flow server (REST API, not Dev UI).
# Local: http://localhost:4001   (Dev UI is on 4000)
# Cloud Run: https://spectre-gold-genkit-xxxx-uc.a.run.app
GENKIT_FLOW_URL=http://localhost:4001
FLOW_SERVER_PORT=4001

# ── Backend FastAPI ───────────────────────────────────────────────────────────
# Port for Backend/main.py (default: 8010)
BACKEND_PORT=8010

# ── Streamlit ─────────────────────────────────────────────────────────────────
# Base URL for the FastAPI backend (used by app.py)
# Local: http://localhost:8010
# Cloud Run: https://spectre-gold-backend-xxxx-uc.a.run.app
API_BASE_URL=http://localhost:8010

# ── Context / Retrieval Layer ─────────────────────────────────────────────────
# Default: Google Search Grounding (via Gemini built-in tool) — no extra config needed.
#
# To enable Vertex AI Search (grounded RAG against a curated datastore):
#   1. Create a datastore in GCP Console → Vertex AI Search
#   2. Install: pip install google-cloud-discoveryengine
#   3. Set ADC credentials: gcloud auth application-default login
#   4. Fill in the datastore resource path below:
#
# VERTEX_SEARCH_DATASTORE_ID=projects/PROJECT_ID/locations/global/collections/default_collection/dataStores/DATASTORE_ID
# VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_DATASTORE_ID=
VERTEX_SEARCH_LOCATION=global

# ── Optional: Google Cloud (for Cloud Run deployment) ────────────────────────
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
